# Данные OAuth-приложения, зарегистрированного вами на https://oauth.yandex.ru
# Подробности регистрации — см. README.md, раздел "Регистрация OAuth-приложения".
#
# Префикс MAIN_VITE_ обязателен: electron-vite инлайнит в main-процесс через
# import.meta.env только переменные с этим префиксом (см. electron.vite.config.ts).

# Client ID вашего OAuth-приложения (тип — "Веб-сервисы", Implicit flow)
MAIN_VITE_YANDEX_CLIENT_ID=your_client_id_here

# Redirect URI должен буквально совпадать с тем, что указано в настройках
# приложения на oauth.yandex.ru. Если поле "Redirect URI для веб-сервисов"
# заблокировано для редактирования — оставьте значение по умолчанию ниже,
# приложение перехватывает токен из адресной строки раньше, чем эта страница
# успевает отрисоваться, так что вручную ничего копировать не придётся.
MAIN_VITE_YANDEX_REDIRECT_URI=https://oauth.yandex.ru/verification_code
